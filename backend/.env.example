# Archflow Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Required: Groq API key for AI generation and analysis
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: GitHub Personal Access Token
# Increases rate limit from 60 to 5000 requests/hour when parsing repositories
# Generate at https://github.com/settings/tokens (no special scopes required)
GITHUB_TOKEN=

# Database connection string
# Default: local SQLite file (no setup required)
# PostgreSQL example: postgresql://user:password@localhost:5432/archflow
DATABASE_URL=sqlite:///./archflow.db
